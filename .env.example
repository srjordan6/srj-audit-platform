# SRJ AI Audit Platform — environment variables template
# Copy to .env for local development. Never commit .env.
# In production, set each variable in the Render dashboard.

# Django core
SECRET_KEY=replace-with-output-of-python-c-import-secrets-print-secrets-token-urlsafe-50
DEBUG=False
ALLOWED_HOSTS=aiauditforcompanies.com,srj-audit-web.onrender.com,localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=audit_platform.settings.production

# Database — Render auto-injects DATABASE_URL in production
DATABASE_URL=postgres://postgres:devpass@localhost:5432/srj_audit

# Redis — Render auto-injects REDIS_URL in production
REDIS_URL=redis://localhost:6379/0

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_replace
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace
STRIPE_IDENTITY_WEBHOOK_SECRET=whsec_replace
TIER_1_REPORT_PRICE_CENTS=19900
STRIPE_IDENTITY_REQUIRED_THRESHOLD_EMPLOYEES=501

# Postmark
POSTMARK_API_TOKEN=replace
POSTMARK_FROM_EMAIL=audit@aiauditforcompanies.com
POSTMARK_FROM_NAME=SRJ Consulting

# Backblaze B2 (S3-compatible)
B2_ACCESS_KEY_ID=replace
B2_SECRET_ACCESS_KEY=replace
B2_BUCKET_NAME=srj-audit-documents
B2_REGION=us-west-002
B2_ENDPOINT_URL=https://s3.us-west-002.backblazeb2.com

# Sentry
SENTRY_DSN=https://example@sentry.io/replace
SENTRY_ENVIRONMENT=development

# Application
PLATFORM_BASE_URL=https://aiauditforcompanies.com
DEFAULT_TIMEZONE=America/Chicago
